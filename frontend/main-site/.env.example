# --- Yerel (.env.local) ---
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# --- Vercel: tarayıcı mixed content istemez ---
# Sunucu tarafı rewrite hedefi (Dashboard → Environment Variables). İstemciye sızmaz.
BACKEND_API_ORIGIN=http://209.38.224.246:8080

# İstemcide doğrudan HTTPS API varsa (sertifikalı domain); yoksa boş bırak — otomatik /api/gw proxy kullanılır.
# NEXT_PUBLIC_GATEWAY_URL=https://api.yourdomain.com

# Zorunlu proxy kökü (nadiren)
# NEXT_PUBLIC_USE_API_PROXY=true

# Servis başına override (genelde gerekmez)
# NEXT_PUBLIC_API_BASE_URL=
# NEXT_PUBLIC_USER_API_BASE_URL=
# NEXT_PUBLIC_PAYMENT_API_URL=
