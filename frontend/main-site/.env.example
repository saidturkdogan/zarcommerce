# Kopyala: cp .env.example .env.local  (Next.js .env.local dosyası gitignore'da)
# Vercel: Project → Settings → Environment Variables (aynı isimler)

# API Gateway kökü (ör. https://api.example.com veya http://localhost:8080)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8082
NEXT_PUBLIC_USER_API_BASE_URL=http://localhost:8081

# Ödeme servisi; gateway kullanıyorsan genelde gateway ile aynı kök
NEXT_PUBLIC_PAYMENT_API_URL=http://localhost:8085

# Bazı sayfalarda fallback: NEXT_PUBLIC_PAYMENT_API_URL yoksa kullanılır
# NEXT_PUBLIC_API_URL=http://localhost:8080
