# Kopyala: cp .env.example .env.local  (Next.js .env.local gitignore'da)
# Vercel: Project → Settings → Environment Variables

# Tek gateway kökü (tüm /api/v1/*). Kod içinde varsayılan da buna yakın; burada override edebilirsin.
# Yerel: http://localhost:8080
NEXT_PUBLIC_GATEWAY_URL=http://209.38.224.246:8080

# İstersen servis başına ayrı (genelde gerekmez); yoksa GATEWAY_URL kullanılır.
# NEXT_PUBLIC_API_BASE_URL=http://209.38.224.246:8080
# NEXT_PUBLIC_USER_API_BASE_URL=http://209.38.224.246:8080
# NEXT_PUBLIC_PAYMENT_API_URL=http://209.38.224.246:8080
